# Shared config — dùng cho cả center lẫn tất cả edge nodes

# Image versions — pin exact patch để tránh surprise update
ENVOY_VERSION=v1.29-latest
VECTOR_VERSION=0.38.0-alpine
LOKI_VERSION=2.9.4
GRAFANA_VERSION=11.0.0

# Center — Loki endpoint dùng bởi Vector trên edge nodes
# Same host:       LOKI_ENDPOINT=http://loki:3100  (Docker DNS)
# Different host:  LOKI_ENDPOINT=http://<center-ip>:3100
LOKI_ENDPOINT=http://loki:3100

# Center ports (exposed trên host)
LOKI_PORT=3100
GRAFANA_PORT=3000

# TLS certs directory (mounted as /certs inside container)
CERTS_PATH=./certs

# Vector resource limits per edge instance
VECTOR_CPU_LIMIT=0.20
VECTOR_MEMORY_LIMIT=256M

# Loki + Grafana resource limits (center)
LOKI_CPU_LIMIT=1.0
LOKI_MEMORY_LIMIT=1.5G
GRAFANA_CPU_LIMIT=0.5
GRAFANA_MEMORY_LIMIT=512M
